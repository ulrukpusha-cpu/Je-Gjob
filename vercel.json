{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/wave-qr.pdf",
      "headers": [
        { "key": "Content-Disposition", "value": "inline" }
      ]
    },
    {
      "source": "/wave-qr.png",
      "headers": [
        { "key": "Content-Disposition", "value": "inline" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
